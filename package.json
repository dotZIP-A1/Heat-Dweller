{
  "name": "heat-dweller",
  "version": "1.0.0",
  "description": "A close-to-home roguelite game where you travel through your house as different characters, surive RNG situations where no exact playthrough is the same, and uncover the mystery behind the arsonist.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --windows",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotZIP-A1/heat-dweller.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.dotzip.heatdweller",
    "productName": "Heat Dweller",
    "asar": false,
    "files": [
      "**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "bugs": {
    "url": "https://github.com/dotZIP-A1/heat-dweller/issues"
  },
